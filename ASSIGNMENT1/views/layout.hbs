{{! Global View Template in HBS format }}

<html>
  <head>
    <title>{{title}} | Prabesh Chhetri</title>

    <link rel="stylesheet" href="/stylesheets/style.css" />

    {{! Bootstrap CSS }}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
  </head>

  <body>
    {{! Header / Jumbotron }}
    <div class="p-5 bg-primary text-white text-center">
      <h1>Prabesh Chhetri</h1>
      <p>Interactive Media Design Web Student | Web Developer Portfolio</p>
    </div>

    {{! Navbar }}
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <ul class="navbar-nav mx-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/about">About Me</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/projects">Projects</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/contact">Contact Me</a>
          </li>
        </ul>
      </div>
    </nav>

    {{! Page content renders here }}
    <main class="container mt-5">
      {{{body}}}
    </main>

    {{! Footer }}
    <footer class="bg-dark text-white text-center p-4 mt-5">
      <p>&copy; 2026 Prabesh Chhetri</p>

      <a href="https://github.com/prabeshchhetri" target="_blank" class="text-white">
        GitHub
      </a>

      <span class="mx-2">|</span>

      <a href="https://www.linkedin.com/" target="_blank" class="text-white">
        LinkedIn
      </a>
    </footer>

    {{! Bootstrap JS }}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>